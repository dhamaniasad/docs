                },
                "text": {
                  "type": "string",
                  "description": "Message content."
                },
                "timestamp": {
                  "type": "string",
                  "format": "date-time",
                  "description": "When the message was sent."
                }
              }
            }
          },
          "total": {
            "type": "integer",
            "description": "Total number of messages."
          },
          "platformConversationId": {
