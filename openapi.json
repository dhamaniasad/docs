          },
          "total": {
            "type": "integer",
            "description": "Total number of conversations matching the filter."
          },
          "totalPages": {
            "type": "integer",
            "description": "Total number of pages."
          }
        }
      },
      "ConversationDetailResponse": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "Internal conversation ID."
          },
          "title": {
